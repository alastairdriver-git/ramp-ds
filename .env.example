# GitHub OAuth (for feedback system)
# Create an OAuth App at: https://github.com/settings/developers
# Homepage URL: http://localhost:3000 (dev) or https://ramp-ds.vercel.app (prod)
# Callback URL: http://localhost:3000/api/auth/callback/github (dev) or https://ramp-ds.vercel.app/api/auth/callback/github (prod)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here
